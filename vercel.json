{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/work", "destination": "/#work", "permanent": true },
    { "source": "/about", "destination": "/#about", "permanent": true },
    { "source": "/contact", "destination": "/#contact", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]
}
